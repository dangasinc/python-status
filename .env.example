# Required: the WhatsApp number to pair, digits only, country code, no "+".
# Leave this unset to be prompted for it interactively in the terminal
# instead (only asked when a fresh pairing is actually needed).
PHONE_NUMBER=255617393825

# Where the session database lives. Defaults to a stable folder next to
# this project (data/session.db3), so restarting locally reuses the same
# session automatically. On Railway, mount a Volume and point this at it
# instead (e.g. /data/session.db3) so it survives redeploys.
SESSION_DB_PATH=/data/session.db3

# Feature toggles.
VIEW_STATUSES=true
LIKE_STATUSES=true
REACTION_EMOJI=

# Send a confirmation message to the connected account's own WhatsApp
# inbox ("Message Yourself") once the bot connects successfully.
NOTIFY_ON_STARTUP=true
STARTUP_NOTIFICATION_MESSAGE=> 🟢 ESSENCE AUTO CONNECTED

# Randomized delay (seconds) before reacting to a status.
MIN_REACT_DELAY_SECONDS=2
MAX_REACT_DELAY_SECONDS=8

# Optional: comma-separated list of phone numbers (digits only) to restrict
# view/like behavior to. Leave empty to act on every visible status.
ALLOWED_STATUS_SENDERS=

LOG_LEVEL=INFO

# Railway sets this automatically; only needed for local runs.
PORT=8080
